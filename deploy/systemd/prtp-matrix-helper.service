[Unit]
Description=PRTP matrix TCP/2222 helper
After=network-online.target
Wants=network-online.target
Before=prtp-bridge.target

[Service]
Type=simple
User=@@SERVICE_USER@@
Group=@@SERVICE_USER@@
WorkingDirectory=/opt/kroma
RuntimeDirectory=kroma
RuntimeDirectoryMode=0755
ExecStart=/opt/kroma/prtp-matrix-helper -config /etc/kroma/prtp-bridge.json
Restart=always
RestartSec=2
KillSignal=SIGTERM
TimeoutStopSec=10
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
